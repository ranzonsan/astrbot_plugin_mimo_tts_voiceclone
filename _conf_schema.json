{
  "api_key": {
    "description": "Mimo TTS API Key",
    "type": "string",
    "hint": "小米 Mimo TTS 服务的 API 密钥",
    "obvious_hint": true
  },
  "base_url": {
    "description": "API Base URL",
    "type": "string",
    "default": "https://api.xiaomi.com/v1",
    "hint": "Mimo TTS API 的基础 URL 地址"
  },
  "trigger_probability": {
    "description": "触发声音克隆的概率",
    "type": "float",
    "default": 0.5,
    "hint": "LLM 回复触发声音克隆的概率，范围 0-1。0 表示从不触发，1 表示总是触发",
    "slider": {
      "min": 0,
      "max": 1,
      "step": 0.05
    }
  },
  "reference_audio": {
    "type": "file",
    "description": "参考音频文件",
    "default": [],
    "file_types": ["wav", "mp3", "flac", "ogg"],
    "hint": "上传用于声音克隆的参考音频文件，支持 WAV、MP3、FLAC、OGG 格式"
  },
  "model_name": {
    "description": "TTS 模型名称",
    "type": "string",
    "default": "mimo-v2.5-tts-voiceclone",
    "hint": "使用的 TTS 模型名称"
  },
  "output_format": {
    "description": "输出音频格式",
    "type": "string",
    "default": "wav",
    "options": ["wav", "mp3", "ogg", "flac"],
    "hint": "生成的音频文件格式"
  },
  "voice_speed": {
    "description": "语音速度",
    "type": "float",
    "default": 1.0,
    "hint": "语音播放速度，1.0 为正常速度",
    "slider": {
      "min": 0.5,
      "max": 2.0,
      "step": 0.1
    }
  },
  "max_text_length": {
    "description": "最大文本长度",
    "type": "int",
    "default": 500,
    "hint": "单次 TTS 转换的最大文本长度，超过此长度将被截断"
  }
}
